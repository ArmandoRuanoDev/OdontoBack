# Base de datos
SUPABASE_URL=link_de_supabase
SUPABASE_KEY=llave_de_supabase

# Configuración de app
DEFAULT_ROLE_ID=id_role
NODE_ENV=development # production

# Llaves para Stripe
STRIPE_SECRET_KEY=llave_secreta_stripe
STRIPE_WEBHOOK_SECRET=llave_webhook_stripe
DEFAULT_TRIAL_PRICE_ID=precio_defecto_stripe

# Token
JWT_ACCESS_SECRET=llave_de_access_jwt
JWT_REFRESH_SECRET=llave_de_refresh_jwt
JWT_ACCESS_EXPIRES_IN=minutes # 1m
JWT_REFRESH_EXPIRES_IN=seconds # 1000

# Servicio de correos
# Para desarrollo (Gmail)
GMAIL_USER=correo_gmail
GMAIL_APP_PASSWORD=llave_gmail

# Para producción (AWS SES)
AWS_ACCESS_KEY_ID=llave_aws_is
AWS_SECRET_ACCESS_KEY=llave_aws_access
AWS_REGION=region
SES_FROM_EMAIL=noreply@tudominio.com

# Frontend URL (para enlaces en correos)
FRONTEND_URL=url_frontend