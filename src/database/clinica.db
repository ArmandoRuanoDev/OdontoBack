CREATE SCHEMA IF NOT EXISTS clinica;

CREATE TABLE clinica."tPaciente" (
    id_paciente INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_doctor INT NOT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE RESTRICT,
    
    -- Información básica
    nombre VARCHAR(60) NOT NULL,
    apellido_paterno VARCHAR(60),
    apellido_materno VARCHAR(60),
    fecha_nacimiento DATE,
    sexo CHAR(1) CHECK (sexo IN ('M','F', 'O')),
    correo_electronico VARCHAR(150),
    telefono_principal VARCHAR(15) NOT NULL,
    telefono_secundario VARCHAR(15),
    
    -- Dirección
    calle VARCHAR(100),
    numero_exterior VARCHAR(10),
    numero_interior VARCHAR(10),
    colonia VARCHAR(80),
    ciudad VARCHAR(80),
    estado VARCHAR(50),
    codigo_postal VARCHAR(10),
    pais VARCHAR(50) DEFAULT 'México',
    
    -- Contacto de emergencia
    contacto_emergencia_nombre VARCHAR(120),
    contacto_emergencia_parentesco VARCHAR(50),
    contacto_emergencia_telefono VARCHAR(15),
    
    -- Ocupación y referido
    ocupacion VARCHAR(100),
    referido_por VARCHAR(100),
    
    -- Control
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP,
    activo BOOLEAN DEFAULT TRUE,
    
    UNIQUE(id_doctor, correo_electronico) -- El correo puede repetirse entre doctores distintos
);

CREATE TABLE clinica."tHistoriaMedica" (
    id_historia_medica INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_paciente INT NOT NULL REFERENCES clinica."tPaciente"(id_paciente) ON DELETE CASCADE,
    
    -- Condiciones médicas (booleanas para las más comunes)
    diabetes BOOLEAN DEFAULT FALSE,
    hipertension BOOLEAN DEFAULT FALSE,
    cardiopatia BOOLEAN DEFAULT FALSE,
    epilepsia BOOLEAN DEFAULT FALSE,
    hepatitis BOOLEAN DEFAULT FALSE,
    vih BOOLEAN DEFAULT FALSE,
    tuberculosis BOOLEAN DEFAULT FALSE,
    asma BOOLEAN DEFAULT FALSE,
    alergias_medicamentos BOOLEAN DEFAULT FALSE,
    alergias_anestesicos BOOLEAN DEFAULT FALSE,
    embarazo BOOLEAN DEFAULT FALSE,
    
    -- Detalles adicionales
    otras_enfermedades TEXT,
    medicamentos_actuales TEXT,
    alergias_detalle TEXT,
    cirugias_previas TEXT,
    hospitalizaciones TEXT,
    transfusiones BOOLEAN DEFAULT FALSE,
    fuma VARCHAR(50),
    alcohol VARCHAR(50),
    drogas BOOLEAN DEFAULT FALSE,
    
    -- Fecha de última actualización
    fecha_actualizacion TIMESTAMP DEFAULT NOW(),
    
    UNIQUE(id_paciente)
);

CREATE TABLE clinica."tHistoriaDental" (
    id_historia_dental INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_paciente INT NOT NULL REFERENCES clinica."tPaciente"(id_paciente) ON DELETE CASCADE,
    
    -- Motivo de consulta principal
    motivo_consulta TEXT,
    
    -- Hábitos
    cepillado_frecuencia VARCHAR(50), -- '1 vez', '2 veces', '3 o más'
    usa_hilo_dental BOOLEAN DEFAULT FALSE,
    usa_enjuague BOOLEAN DEFAULT FALSE,
    bruxismo BOOLEAN DEFAULT FALSE,
    muerde_unas BOOLEAN DEFAULT FALSE,
    respiracion_bucal BOOLEAN DEFAULT FALSE,
    
    -- Antecedentes de tratamientos
    tratamiento_ortodoncia BOOLEAN DEFAULT FALSE,
    cirugia_oral BOOLEAN DEFAULT FALSE,
    extracciones_previas TEXT,
    sensibilidad_dental BOOLEAN DEFAULT FALSE,
    sangrado_encias BOOLEAN DEFAULT FALSE,
    dolor_articulacion BOOLEAN DEFAULT FALSE,
    
    -- Última visita al dentista
    ultima_visita DATE,
    
    fecha_actualizacion TIMESTAMP DEFAULT NOW(),
    
    UNIQUE(id_paciente)
);

CREATE TABLE clinica."tTratamiento" (
    id_tratamiento INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_doctor INT NOT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE CASCADE,
    
    codigo VARCHAR(20),          -- Código interno o de nomenclatura dental
    nombre VARCHAR(100) NOT NULL,
    descripcion TEXT,
    costo_sugerido DECIMAL(10,2),
    duracion_minutos INT,
    color VARCHAR(7),            -- Para representación visual en agenda (#RRGGBB)
    activo BOOLEAN DEFAULT TRUE,
    
    UNIQUE(id_doctor, codigo)
);

CREATE TABLE clinica."tCita" (
    id_cita INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_paciente INT NOT NULL REFERENCES clinica."tPaciente"(id_paciente) ON DELETE CASCADE,
    id_doctor INT NOT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE CASCADE,
    
    fecha_hora_inicio TIMESTAMP NOT NULL,
    fecha_hora_fin TIMESTAMP NOT NULL,
    
    estado VARCHAR(20) DEFAULT 'programada' CHECK (estado IN ('programada', 'confirmada', 'en_curso', 'completada', 'cancelada', 'no_asistio')),
    tipo_cita VARCHAR(30), -- 'primera_vez', 'revision', 'tratamiento', 'urgencia'
    notas TEXT,
    color VARCHAR(7),      -- Color personalizado para la cita
    
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP,
    
    CONSTRAINT check_horario CHECK (fecha_hora_fin > fecha_hora_inicio)
);

CREATE TABLE clinica."tTratamientoRealizado" (
    id_tratamiento_realizado INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_paciente INT NOT NULL REFERENCES clinica."tPaciente"(id_paciente) ON DELETE CASCADE,
    id_doctor INT NOT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE CASCADE,
    id_tratamiento INT REFERENCES clinica."tTratamiento"(id_tratamiento) ON DELETE SET NULL,
    id_cita INT REFERENCES clinica."tCita"(id_cita) ON DELETE SET NULL,
    
    fecha_tratamiento DATE DEFAULT CURRENT_DATE,
    diente VARCHAR(5),               -- Notación FDI (11, 21, 36, etc.) o múltiples separadas por coma
    caras VARCHAR(20),               -- Caras tratadas: O, M, D, V, L/P, I
    diagnostico TEXT,
    procedimiento_realizado TEXT,
    observaciones TEXT,
    costo_cobrado DECIMAL(10,2),
    
    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE clinica."tOdontograma" (
    id_odontograma INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_paciente INT NOT NULL REFERENCES clinica."tPaciente"(id_paciente) ON DELETE CASCADE,
    
    diente VARCHAR(3) NOT NULL,      -- Notación FDI de dos dígitos (ej. '11', '36')
    estado VARCHAR(30),              -- 'sano', 'caries', 'obturacion', 'corona', 'ausente', 'endodoncia', 'implante', etc.
    superficie JSONB,                -- Detalle por cara: {"O":"caries", "M":"obturacion", "D":"sano"}
    notas TEXT,
    
    fecha_actualizacion TIMESTAMP DEFAULT NOW(),
    
    UNIQUE(id_paciente, diente)
);

CREATE TABLE clinica."tNotaClinica" (
    id_nota INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_paciente INT NOT NULL REFERENCES clinica."tPaciente"(id_paciente) ON DELETE CASCADE,
    id_doctor INT NOT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE CASCADE,
    id_cita INT REFERENCES clinica."tCita"(id_cita) ON DELETE SET NULL,
    
    fecha_nota DATE DEFAULT CURRENT_DATE,
    subjetivo TEXT,
    objetivo TEXT,
    analisis TEXT,
    plan TEXT,
    notas_adicionales TEXT,
    
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP
);

CREATE TABLE clinica."tDocumentoPaciente" (
    id_documento INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_paciente INT NOT NULL REFERENCES clinica."tPaciente"(id_paciente) ON DELETE CASCADE,
    id_doctor INT NOT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE CASCADE,
    id_tratamiento_realizado INT REFERENCES clinica."tTratamientoRealizado"(id_tratamiento_realizado) ON DELETE SET NULL,
    
    tipo_documento VARCHAR(30) CHECK (tipo_documento IN ('radiografia', 'foto_clinica', 'consentimiento', 'receta', 'otro')),
    nombre_archivo VARCHAR(255) NOT NULL,
    ruta_almacenamiento TEXT NOT NULL,   -- URL o path en bucket (S3, Supabase Storage)
    mime_type VARCHAR(100),
    tamanio_bytes INT,
    descripcion TEXT,
    
    fecha_subida TIMESTAMP DEFAULT NOW()
);

CREATE TABLE clinica."lClinica" (
    id_log_clinica INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_usuario INT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE SET NULL,
    mensaje_error VARCHAR(500),
    detalle_error TEXT,
    clase VARCHAR(100),
    metodo VARCHAR(100),
    ip_address INET,
    user_agent TEXT,
    fecha_error_log TIMESTAMP DEFAULT NOW()
);

-- Índices para búsquedas frecuentes
CREATE INDEX idx_paciente_doctor ON clinica."tPaciente" (id_doctor);
CREATE INDEX idx_paciente_nombre ON clinica."tPaciente" (nombre, apellido_paterno, apellido_materno);
CREATE INDEX idx_paciente_telefono ON clinica."tPaciente" (telefono_principal);

CREATE INDEX idx_historia_paciente ON clinica."tHistoriaMedica" (id_paciente);

CREATE INDEX idx_documento_paciente ON clinica."tDocumentoPaciente" (id_paciente);

CREATE INDEX idx_nota_paciente ON clinica."tNotaClinica" (id_paciente);

CREATE INDEX idx_tr_realizado_paciente ON clinica."tTratamientoRealizado" (id_paciente);
CREATE INDEX idx_tr_realizado_fecha ON clinica."tTratamientoRealizado" (fecha_tratamiento);

CREATE INDEX idx_cita_doctor_fecha ON clinica."tCita" (id_doctor, fecha_hora_inicio);
CREATE INDEX idx_cita_paciente ON clinica."tCita" (id_paciente);

CREATE INDEX idx_tratamiento_doctor ON clinica."tTratamiento" (id_doctor);

CREATE INDEX idx_odontograma_paciente ON clinica."tOdontograma" (id_paciente);

CREATE INDEX idx_log_fecha ON clinica."lClinica" (fecha_error_log);
CREATE INDEX idx_log_usuario ON clinica."lClinica" (id_usuario);
CREATE INDEX idx_log_ip ON clinica."lClinica" (ip_address);

-- Funciones
CREATE OR REPLACE FUNCTION clinica.crear_paciente(
    _id_doctor INT,
    _nombre VARCHAR,
    _telefono_principal VARCHAR,
    _apellido_paterno VARCHAR DEFAULT NULL,
    _apellido_materno VARCHAR DEFAULT NULL,
    _fecha_nacimiento DATE DEFAULT NULL,
    _sexo CHAR DEFAULT NULL,
    _correo_electronico VARCHAR DEFAULT NULL,
    _telefono_secundario VARCHAR DEFAULT NULL,
    _calle VARCHAR DEFAULT NULL,
    _numero_exterior VARCHAR DEFAULT NULL,
    _numero_interior VARCHAR DEFAULT NULL,
    _colonia VARCHAR DEFAULT NULL,
    _ciudad VARCHAR DEFAULT NULL,
    _estado VARCHAR DEFAULT NULL,
    _codigo_postal VARCHAR DEFAULT NULL,
    _pais VARCHAR DEFAULT 'México',
    _contacto_emergencia_nombre VARCHAR DEFAULT NULL,
    _contacto_emergencia_parentesco VARCHAR DEFAULT NULL,
    _contacto_emergencia_telefono VARCHAR DEFAULT NULL,
    _ocupacion VARCHAR DEFAULT NULL,
    _referido_por VARCHAR DEFAULT NULL
)
RETURNS INT AS $$
DECLARE
    nuevo_id INT;
BEGIN
    INSERT INTO clinica."tPaciente" (
        id_doctor, nombre, apellido_paterno, apellido_materno,
        fecha_nacimiento, sexo, telefono_principal, correo_electronico,
        telefono_secundario, calle, numero_exterior, numero_interior,
        colonia, ciudad, estado, codigo_postal, pais,
        contacto_emergencia_nombre, contacto_emergencia_parentesco,
        contacto_emergencia_telefono, ocupacion, referido_por
    ) VALUES (
        _id_doctor, _nombre, _apellido_paterno, _apellido_materno,
        _fecha_nacimiento, _sexo, _telefono_principal, _correo_electronico,
        _telefono_secundario, _calle, _numero_exterior, _numero_interior,
        _colonia, _ciudad, _estado, _codigo_postal, _pais,
        _contacto_emergencia_nombre, _contacto_emergencia_parentesco,
        _contacto_emergencia_telefono, _ocupacion, _referido_por
    )
    RETURNING id_paciente INTO nuevo_id;
    
    INSERT INTO clinica."tHistoriaMedica" (id_paciente) VALUES (nuevo_id);
    INSERT INTO clinica."tHistoriaDental" (id_paciente) VALUES (nuevo_id);
    
    RETURN nuevo_id;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE OR REPLACE FUNCTION clinica.obtener_expediente(_id_paciente INT)
RETURNS JSON AS $$
DECLARE
    resultado JSON;
BEGIN
    SELECT json_build_object(
        'paciente', row_to_json(p),
        'historia_medica', row_to_json(hm),
        'historia_dental', row_to_json(hd),
        'ultimas_citas', (SELECT json_agg(row_to_json(c)) FROM clinica."tCita" c WHERE c.id_paciente = _id_paciente ORDER BY c.fecha_hora_inicio DESC LIMIT 10),
        'ultimos_tratamientos', (SELECT json_agg(row_to_json(tr)) FROM clinica."tTratamientoRealizado" tr WHERE tr.id_paciente = _id_paciente ORDER BY tr.fecha_tratamiento DESC LIMIT 20),
        'odontograma', (SELECT json_agg(row_to_json(o)) FROM clinica."tOdontograma" o WHERE o.id_paciente = _id_paciente)
    )
    INTO resultado
    FROM clinica."tPaciente" p
    LEFT JOIN clinica."tHistoriaMedica" hm ON p.id_paciente = hm.id_paciente
    LEFT JOIN clinica."tHistoriaDental" hd ON p.id_paciente = hd.id_paciente
    WHERE p.id_paciente = _id_paciente;
    
    RETURN resultado;
END;
$$ LANGUAGE plpgsql STABLE;


-- Permisos
GRANT USAGE ON SCHEMA clinica TO anon, authenticated, service_role;
GRANT ALL ON ALL TABLES IN SCHEMA clinica TO anon, authenticated, service_role;
ALTER DEFAULT PRIVILEGES IN SCHEMA clinica GRANT ALL ON TABLES TO anon, authenticated, service_role;