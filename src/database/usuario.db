CREATE TABLE usuario."tRolUsuario" (
    id_rol INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    nombre_rol VARCHAR(40) NOT NULL,
    descripcion_rol VARCHAR(200) NULL,
    estatus_rol BOOLEAN DEFAULT TRUE
);

CREATE TABLE usuario."tUsuario" (
    id_usuario INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    nombre_usuario VARCHAR(60) NOT NULL,
    apellido_paterno VARCHAR(60),
    apellido_materno VARCHAR(60),
    correo_electronico VARCHAR(150) UNIQUE NOT NULL,
    correo_verificado BOOLEAN DEFAULT FALSE,
    numero_telefono VARCHAR(13) NOT NULL,
    foto_perfil TEXT,
    fecha_nacimiento DATE,
    sexo_usuario CHAR(1) CHECK (sexo_usuario IN ('M','F')),
    contrasena_hash TEXT NOT NULL,
    acepta_aviso_privacidad BOOLEAN DEFAULT FALSE,
    fecha_aceptacion_aviso TIMESTAMP,
    acepta_terminos_condiciones BOOLEAN DEFAULT FALSE,
    fecha_aceptacion_terminos TIMESTAMP,
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP NULL,
    id_rol_usuario INT REFERENCES usuario."tRolUsuario"(id_rol)
);

CREATE TABLE usuario."tAcceso" (
    id_acceso INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_usuario INT UNIQUE NOT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE CASCADE,
    ultimo_acceso TIMESTAMP,
    ultimo_intento_fallido TIMESTAMP,
    intentos_fallidos INT DEFAULT 0 CHECK (intentos_fallidos >= 0),
    bloqueado_hasta TIMESTAMP, -- NULL = no bloqueado, fecha futura = bloqueado hasta ese momento
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE usuario."lAcceso" (
    id_log_acceso INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_usuario INT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE SET NULL,
    mensaje_error VARCHAR(500),
    detalle_error TEXT,
    clase VARCHAR(100),
    metodo VARCHAR(100),
    ip_address INET,
    user_agent TEXT,
    fecha_error_log TIMESTAMP DEFAULT NOW()
);

CREATE TABLE usuario."tSesion" (
    id_sesion UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_usuario INT NOT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE CASCADE,
    refresh_token_hash TEXT NOT NULL,
    ip_address INET,
    user_agent TEXT,
    created_at TIMESTAMP DEFAULT NOW(),
    expires_at TIMESTAMP NOT NULL,
    revoked BOOLEAN DEFAULT FALSE,
    revoked_at TIMESTAMP
);

CREATE TABLE usuario."tTipoSuscripcion" (
    id_tipo_suscripcion INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    nombre VARCHAR(50) NOT NULL,
    descripcion TEXT,
    duracion_dias INT,
    precio DECIMAL(10,2) NOT NULL,
    moneda CHAR(3) DEFAULT 'MXN',
    activo BOOLEAN DEFAULT TRUE
);

CREATE TABLE usuario."tUsuarioSuscripcion" (
    id_suscripcion INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_usuario INT NOT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE CASCADE,
    id_tipo_suscripcion INT NOT NULL REFERENCES usuario."tTipoSuscripcion"(id_tipo_suscripcion),
    fecha_inicio TIMESTAMP DEFAULT NOW(),
    fecha_fin TIMESTAMP,
    estado VARCHAR(20) DEFAULT 'activa' CHECK (estado IN ('activa', 'cancelada', 'expirada', 'pendiente')),
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP NULL
);

-- Índices
CREATE INDEX IF NOT EXISTS idx_usuario_telefono ON usuario."tUsuario" (numero_telefono);
CREATE INDEX IF NOT EXISTS idx_usuario_correo ON usuario."tUsuario" (correo_electronico);
CREATE INDEX IF NOT EXISTS idx_acceso_id_usuario ON usuario."tAcceso" (id_usuario);

CREATE INDEX idx_sesion_usuario ON usuario."tSesion" (id_usuario);
CREATE INDEX idx_sesion_expires ON usuario."tSesion" (expires_at);
CREATE INDEX idx_sesion_token_hash ON usuario."tSesion" (refresh_token_hash);
CREATE INDEX idx_sesion_revoked ON usuario."tSesion" (revoked) WHERE revoked = FALSE;
CREATE INDEX idx_acceso_bloqueo ON usuario."tAcceso" (bloqueado_hasta) WHERE bloqueado_hasta IS NOT NULL;

CREATE INDEX idx_log_fecha ON usuario."lAcceso" (fecha_error_log);
CREATE INDEX idx_log_usuario ON usuario."lAcceso" (id_usuario);
CREATE INDEX idx_log_ip ON usuario."lAcceso" (ip_address);

CREATE INDEX idx_usuario_suscripcion ON usuario."tUsuarioSuscripcion" (id_usuario);
CREATE INDEX idx_suscripcion_fecha_fin ON usuario."tUsuarioSuscripcion" (fecha_fin) WHERE estado = 'activa';

