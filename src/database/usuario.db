-- Funciones

-- Registrar usuario
-- Crea usuario + control de acceso + suscripción Inicio

CREATE OR REPLACE FUNCTION usuario.registrar_usuario(
    _nombre_usuario VARCHAR,
    _apellido_paterno VARCHAR,
    _apellido_materno VARCHAR,
    _correo_electronico VARCHAR,
    _numero_telefono VARCHAR,
    _fecha_nacimiento DATE,
    _sexo_usuario CHAR,
    _contrasena_hash TEXT,
    _id_rol_usuario INT,
    _acepta_aviso_privacidad BOOLEAN,
    _acepta_terminos_condiciones BOOLEAN
)
RETURNS JSON AS $$
DECLARE
    nuevo_id INT;
    resultado JSON;
    fecha_ahora TIMESTAMP := NOW();
    id_plan_inicio INT;
BEGIN
    IF _acepta_aviso_privacidad IS FALSE OR _acepta_terminos_condiciones IS FALSE THEN
        RAISE EXCEPTION 'Debe aceptar el aviso de privacidad y los términos y condiciones para registrarse';
    END IF;
 
    INSERT INTO usuario."tUsuario" (
        nombre_usuario, apellido_paterno, apellido_materno,
        correo_electronico, numero_telefono, fecha_nacimiento,
        sexo_usuario, contrasena_hash, id_rol_usuario,
        acepta_aviso_privacidad, fecha_aceptacion_aviso,
        acepta_terminos_condiciones, fecha_aceptacion_terminos
    ) VALUES (
        _nombre_usuario, _apellido_paterno, _apellido_materno,
        _correo_electronico, _numero_telefono, _fecha_nacimiento,
        _sexo_usuario, _contrasena_hash, _id_rol_usuario,
        _acepta_aviso_privacidad, fecha_ahora,
        _acepta_terminos_condiciones, fecha_ahora
    )
    RETURNING id_usuario INTO nuevo_id;
 
    INSERT INTO usuario."tAcceso" (id_usuario)
    VALUES (nuevo_id);
 
    SELECT id_tipo_suscripcion INTO id_plan_inicio
    FROM usuario."tTipoSuscripcion"
    WHERE nombre = 'Inicio' AND activo = TRUE;
 
    INSERT INTO usuario."tUsuarioSuscripcion" (
        id_usuario, id_tipo_suscripcion, fecha_inicio, fecha_fin, estado
    ) VALUES (
        nuevo_id, id_plan_inicio, fecha_ahora, NULL, 'activa'
    );
 
    SELECT json_build_object(
        'id',                   nuevo_id,
        'nombre_usuario',       _nombre_usuario,
        'correo_electronico',   _correo_electronico
    ) INTO resultado;
 
    RETURN resultado;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;


-- Activar prueba de 14 días
-- Se llama cuando el doctor registra su tarjeta en Stripe.
-- Stripe crea el customer_id; se pasa aquí para guardarlo.

CREATE OR REPLACE FUNCTION usuario.activar_prueba_con_suscripcion(
    _id_usuario INT,
    _stripe_customer_id VARCHAR,
    _stripe_payment_method_id VARCHAR,
    _tipo_metodo VARCHAR,
    _marca VARCHAR,
    _ultimos_digitos CHAR(4),
    _expira_mes INT,
    _expira_anio INT,
    _stripe_subscription_id VARCHAR,
    _fecha_fin_trial TIMESTAMP
)
RETURNS JSON AS $$
DECLARE
    fecha_ahora TIMESTAMP := NOW();
    id_plan_prueba INT;
    id_suscripcion_actual INT;
    nueva_suscripcion INT;
BEGIN
    -- Actualizar stripe_customer_id
    UPDATE usuario."tUsuario"
    SET stripe_customer_id = _stripe_customer_id, updated_at = fecha_ahora
    WHERE id_usuario = _id_usuario;

    -- Desmarcar otros métodos y luego insertar/actualizar el nuevo como predeterminado
    UPDATE usuario."tMetodoPago"
    SET es_predeterminado = FALSE
    WHERE id_usuario = _id_usuario AND es_predeterminado = TRUE;

    INSERT INTO usuario."tMetodoPago" (
        id_usuario, stripe_payment_method_id, tipo, marca,
        ultimos_digitos, expira_mes, expira_anio, es_predeterminado
    ) VALUES (
        _id_usuario, _stripe_payment_method_id, _tipo_metodo, _marca,
        _ultimos_digitos, _expira_mes, _expira_anio, TRUE
    )
    ON CONFLICT (stripe_payment_method_id) DO UPDATE
    SET es_predeterminado = TRUE,
        expira_mes = EXCLUDED.expira_mes,
        expira_anio = EXCLUDED.expira_anio,
        marca = EXCLUDED.marca,
        tipo = EXCLUDED.tipo,
        ultimos_digitos = EXCLUDED.ultimos_digitos;

    -- Verificar que el usuario esté en plan Inicio (única prueba posible)
    SELECT us.id_suscripcion INTO id_suscripcion_actual
    FROM usuario."tUsuarioSuscripcion" us
    JOIN usuario."tTipoSuscripcion" ts ON ts.id_tipo_suscripcion = us.id_tipo_suscripcion
    WHERE us.id_usuario = _id_usuario
      AND us.estado = 'activa'
      AND ts.nombre = 'Inicio'
    FOR UPDATE;

    IF id_suscripcion_actual IS NULL THEN
        RAISE EXCEPTION 'El usuario no está en el plan Inicio o ya tuvo una prueba activa';
    END IF;

    IF EXISTS (
        SELECT 1 FROM usuario."tUsuarioSuscripcion" us
        JOIN usuario."tTipoSuscripcion" ts ON ts.id_tipo_suscripcion = us.id_tipo_suscripcion
        WHERE us.id_usuario = _id_usuario AND ts.es_prueba = TRUE
    ) THEN
        RAISE EXCEPTION 'El usuario ya utilizó su período de prueba';
    END IF;

    -- Obtener id del plan Prueba
    SELECT id_tipo_suscripcion INTO id_plan_prueba
    FROM usuario."tTipoSuscripcion"
    WHERE nombre = 'Prueba' AND activo = TRUE;

    -- Expirar suscripción actual (Inicio)
    UPDATE usuario."tUsuarioSuscripcion"
    SET estado = 'expirada', updated_at = fecha_ahora
    WHERE id_suscripcion = id_suscripcion_actual;

    -- Crear suscripción de prueba con referencia a Stripe y fecha_fin
    INSERT INTO usuario."tUsuarioSuscripcion" (
        id_usuario, id_tipo_suscripcion, fecha_inicio, fecha_fin, estado,
        stripe_subscription_id
    ) VALUES (
        _id_usuario, id_plan_prueba,
        fecha_ahora,
        _fecha_fin_trial,
        'activa',
        _stripe_subscription_id
    )
    RETURNING id_suscripcion INTO nueva_suscripcion;

    RETURN json_build_object(
        'ok',               TRUE,
        'id_suscripcion',   nueva_suscripcion,
        'fecha_fin',        _fecha_fin_trial
    );
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;


-- Convertir a plan de pago
-- Se llama desde el webhook de Stripe cuando el pago es exitoso.

CREATE OR REPLACE FUNCTION usuario.convertir_a_plan_pago(
    _id_usuario INT,
    _nombre_plan VARCHAR,
    _stripe_subscription_id VARCHAR,
    _stripe_payment_intent_id VARCHAR,
    _stripe_invoice_id VARCHAR,
    _monto DECIMAL,
    _id_metodo_pago INT,
    _fecha_fin TIMESTAMP DEFAULT NULL
)
RETURNS JSON AS $$
DECLARE
    fecha_ahora TIMESTAMP := NOW();
    id_plan INT;
    duracion INT;
    venia_de_prueba BOOLEAN := FALSE;
    suscripcion_existente RECORD;
    nueva_suscripcion INT;
    fecha_fin_calculada TIMESTAMP;
BEGIN
    SELECT id_tipo_suscripcion, duracion_dias
    INTO id_plan, duracion
    FROM usuario."tTipoSuscripcion"
    WHERE nombre = _nombre_plan AND activo = TRUE;

    IF id_plan IS NULL THEN
        RAISE EXCEPTION 'Plan no encontrado: %', _nombre_plan;
    END IF;

    -- Priorizar la fecha de Stripe; solo calcular si no se proporcionó
    fecha_fin_calculada := CASE
        WHEN _fecha_fin IS NOT NULL THEN _fecha_fin
        WHEN duracion IS NOT NULL THEN fecha_ahora + (duracion || ' days')::INTERVAL
        ELSE NULL
    END;

    SELECT us.id_suscripcion, us.id_tipo_suscripcion, ts.es_prueba
    INTO suscripcion_existente
    FROM usuario."tUsuarioSuscripcion" us
    JOIN usuario."tTipoSuscripcion" ts ON ts.id_tipo_suscripcion = us.id_tipo_suscripcion
    WHERE us.stripe_subscription_id = _stripe_subscription_id
    FOR UPDATE;

    IF suscripcion_existente.id_suscripcion IS NOT NULL THEN
        venia_de_prueba := suscripcion_existente.es_prueba;

        UPDATE usuario."tUsuarioSuscripcion"
        SET id_tipo_suscripcion = id_plan,
            fecha_inicio = fecha_ahora,
            fecha_fin = fecha_fin_calculada,
            estado = 'activa',
            convertida_desde_prueba = venia_de_prueba,
            updated_at = fecha_ahora
        WHERE id_suscripcion = suscripcion_existente.id_suscripcion
        RETURNING id_suscripcion INTO nueva_suscripcion;
    ELSE
        UPDATE usuario."tUsuarioSuscripcion"
        SET estado = 'expirada', updated_at = fecha_ahora
        WHERE id_usuario = _id_usuario AND estado = 'activa';

        INSERT INTO usuario."tUsuarioSuscripcion" (
            id_usuario, id_tipo_suscripcion,
            fecha_inicio, fecha_fin, estado,
            stripe_subscription_id,
            convertida_desde_prueba
        ) VALUES (
            _id_usuario, id_plan,
            fecha_ahora,
            fecha_fin_calculada,
            'activa',
            _stripe_subscription_id,
            FALSE
        )
        RETURNING id_suscripcion INTO nueva_suscripcion;
    END IF;

    INSERT INTO usuario."tPago" (
        id_suscripcion, id_tipo_suscripcion, id_metodo_pago,
        monto, moneda, metodo_pago,
        stripe_payment_intent_id, stripe_invoice_id,
        estado_pago
    )
    SELECT nueva_suscripcion, id_plan, _id_metodo_pago,
           _monto, 'MXN', 'card',
           _stripe_payment_intent_id, _stripe_invoice_id,
           'exitoso'
    WHERE NOT EXISTS (
        SELECT 1 FROM usuario."tPago"
        WHERE stripe_invoice_id = _stripe_invoice_id
    );

    RETURN json_build_object(
        'ok', TRUE,
        'id_suscripcion', nueva_suscripcion,
        'plan', _nombre_plan,
        'desde_prueba', venia_de_prueba
    );
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;


-- Renovar suscripción automaticamente
CREATE OR REPLACE FUNCTION usuario.renovar_suscripcion(
    _stripe_subscription_id VARCHAR,
    _nuevo_monto DECIMAL,
    _stripe_payment_intent_id VARCHAR,
    _stripe_invoice_id VARCHAR
)
RETURNS VOID AS $$
DECLARE
    sub RECORD;
BEGIN
    SELECT us.id_suscripcion, ts.duracion_dias
    INTO sub
    FROM usuario."tUsuarioSuscripcion" us
    JOIN usuario."tTipoSuscripcion" ts ON ts.id_tipo_suscripcion = us.id_tipo_suscripcion
    WHERE us.stripe_subscription_id = _stripe_subscription_id
      AND us.estado = 'activa';

    IF NOT FOUND THEN
        RETURN;
    END IF;

    UPDATE usuario."tUsuarioSuscripcion"
    SET fecha_fin = fecha_fin + (sub.duracion_dias || ' days')::INTERVAL,
        updated_at = NOW()
    WHERE id_suscripcion = sub.id_suscripcion;

    INSERT INTO usuario."tPago" (id_suscripcion, monto, stripe_payment_intent_id, stripe_invoice_id, estado_pago)
    VALUES (sub.id_suscripcion, _nuevo_monto, _stripe_payment_intent_id, _stripe_invoice_id, 'exitoso');
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;


-- Cancelar suscripción (acceso hasta fecha_fin)
-- Stripe gestiona la no renovación; aquí solo marcamos la BD.

CREATE OR REPLACE FUNCTION usuario.cancelar_suscripcion(_id_usuario INT)
RETURNS JSON AS $$
DECLARE
    fecha_fin_actual TIMESTAMP;
BEGIN
    UPDATE usuario."tUsuarioSuscripcion"
    SET cancelar_al_vencer = TRUE, updated_at = NOW()
    WHERE id_usuario = _id_usuario AND estado = 'activa'
    RETURNING fecha_fin INTO fecha_fin_actual;
 
    IF NOT FOUND THEN
        RAISE EXCEPTION 'No se encontró suscripción activa para el usuario %', _id_usuario;
    END IF;
 
    RETURN json_build_object(
        'ok',           TRUE,
        'acceso_hasta', fecha_fin_actual
    );
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;


--  Expirar suscripciones vencidas
--  Ejecutar periódicamente.
--  Stripe maneja renovaciones; esta función solo expira
--  pruebas y suscripciones canceladas que llegaron a su fin.

CREATE OR REPLACE FUNCTION usuario.expirar_suscripciones_vencidas()
RETURNS INTEGER AS $$
DECLARE
    id_plan_inicio  INT;
    total INTEGER := 0;
    actualizadas INTEGER;
    rec RECORD;
BEGIN
    SELECT id_tipo_suscripcion INTO id_plan_inicio
    FROM usuario."tTipoSuscripcion"
    WHERE nombre = 'Inicio' AND activo = TRUE;
 
    -- Expirar suscripciones que llegaron a su fecha_fin
    -- (pruebas expiradas y planes cancelados que llegaron al vencimiento)
    UPDATE usuario."tUsuarioSuscripcion"
    SET estado = 'expirada', updated_at = NOW()
    WHERE estado = 'activa'
      AND fecha_fin IS NOT NULL
      AND fecha_fin < NOW();
 
    GET DIAGNOSTICS actualizadas = ROW_COUNT;
    total := total + actualizadas;
 
    -- Regresar al plan Inicio a quienes expiraron y no tienen plan activo
    FOR rec IN
        SELECT DISTINCT us.id_usuario
        FROM usuario."tUsuarioSuscripcion" us
        WHERE us.estado = 'expirada'
          AND NOT EXISTS (
              SELECT 1 FROM usuario."tUsuarioSuscripcion" us2
              WHERE us2.id_usuario = us.id_usuario
                AND us2.estado = 'activa'
          )
    LOOP
        INSERT INTO usuario."tUsuarioSuscripcion" (
            id_usuario, id_tipo_suscripcion,
            fecha_inicio, fecha_fin, estado
        ) VALUES (
            rec.id_usuario, id_plan_inicio,
            NOW(), NULL, 'activa'
        )
        ON CONFLICT (id_usuario) WHERE estado = 'activa' DO NOTHING;
    END LOOP;
 
    RETURN total;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;


--  Ver plan activo de un usuario
--  Útil para validar límites en el backend.

CREATE OR REPLACE FUNCTION usuario.obtener_plan_activo(_id_usuario INT)
RETURNS JSON AS $$
DECLARE
    resultado JSON;
BEGIN
    SELECT json_build_object(
        'id_suscripcion', us.id_suscripcion,
        'plan', ts.nombre,
        'precio', ts.precio,
        'max_pacientes', ts.max_pacientes,
        'max_citas_mes', ts.max_citas_mes,
        'max_recetas_mes', ts.max_recetas_mes,
        'es_prueba', ts.es_prueba,
        'fecha_fin', us.fecha_fin,
        'cancelar_al_vencer', us.cancelar_al_vencer,
        'stripe_subscription_id', us.stripe_subscription_id
    )
    INTO resultado
    FROM usuario."tUsuarioSuscripcion" us
    JOIN usuario."tTipoSuscripcion" ts ON ts.id_tipo_suscripcion = us.id_tipo_suscripcion
    WHERE us.id_usuario = _id_usuario
      AND us.estado = 'activa'
    LIMIT 1;
 
    RETURN resultado;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;


-- Candado para bloqueo de usuarios
CREATE OR REPLACE FUNCTION usuario.lock_usuario_suscripcion(_id_usuario INT)
RETURNS BOOLEAN
LANGUAGE plpgsql
AS $$
BEGIN
    RETURN pg_try_advisory_xact_lock(_id_usuario);
END;
$$;


-- Ejecutar función diariamente
SELECT cron.schedule(
    'expirar-suscripciones-diario', -- nombre de la tarea
    '0 3 * * *', -- Programación: a las 3:00 AM (UTC) todos los días
    'SELECT usuario.expirar_suscripciones_vencidas();' -- La instrucción SQL
);


