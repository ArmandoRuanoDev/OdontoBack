-- Base de Datos para TODONTO

CREATE TABLE usuario."tRolUsuario" (
    id_rol INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    nombre_rol VARCHAR(40) NOT NULL,
    descripcion_rol VARCHAR(200) NULL,
    estatus_rol BOOLEAN DEFAULT TRUE
);

CREATE TABLE usuario."tTipoSuscripcion" (
    id_tipo_suscripcion INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    nombre VARCHAR(50) NOT NULL,
    descripcion TEXT,
    duracion_dias INT, -- NULL = sin expiración
    precio DECIMAL(10,2) NOT NULL,
    moneda CHAR(3) DEFAULT 'MXN',

    -- Límites del plan (NULL = ilimitado)
    max_pacientes INT NULL,
    max_citas_mes INT NULL,
    max_recetas_mes INT NULL,

    -- Comportamiento
    requiere_metodo_pago BOOLEAN DEFAULT FALSE,
    es_prueba BOOLEAN DEFAULT FALSE, -- true solo para el plan de prueba

    -- Stripe
    stripe_price_id VARCHAR(100) NULL, -- price_xxx de Stripe
    activo BOOLEAN DEFAULT TRUE
);

CREATE TABLE usuario."tUsuario" (
    id_usuario INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    nombre_usuario VARCHAR(60) NOT NULL,
    apellido_paterno VARCHAR(60),
    apellido_materno VARCHAR(60),
    correo_electronico VARCHAR(150) UNIQUE NOT NULL,
    correo_verificado BOOLEAN DEFAULT FALSE,
    numero_telefono VARCHAR(15) NOT NULL,
    foto_perfil TEXT,
    fecha_nacimiento DATE,
    sexo_usuario CHAR(1) CHECK (sexo_usuario IN ('M','F','O')),
    contrasena_hash TEXT NOT NULL,
    acepta_aviso_privacidad BOOLEAN DEFAULT FALSE,
    fecha_aceptacion_aviso TIMESTAMP,
    acepta_terminos_condiciones BOOLEAN DEFAULT FALSE,
    fecha_aceptacion_terminos TIMESTAMP,

    -- Stripe
    stripe_customer_id VARCHAR(100) NULL UNIQUE, -- cus_xxx
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP NULL,
    id_rol_usuario INT REFERENCES usuario."tRolUsuario"(id_rol)
);

CREATE TABLE usuario."tAcceso" (
    id_acceso INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_usuario INT UNIQUE NOT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE CASCADE,
    ultimo_acceso TIMESTAMP,
    ultimo_intento_fallido TIMESTAMP,
    intentos_fallidos INT DEFAULT 0 CHECK (intentos_fallidos >= 0),
    bloqueado_hasta TIMESTAMP, -- NULL = no bloqueado, fecha futura = bloqueado hasta ese momento
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE usuario."lAcceso" (
    id_log_acceso INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_usuario INT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE SET NULL,
    mensaje_error VARCHAR(500),
    detalle_error TEXT,
    clase VARCHAR(100),
    metodo VARCHAR(100),
    ip_address INET,
    user_agent TEXT,
    fecha_error_log TIMESTAMP DEFAULT NOW()
);

CREATE TABLE usuario."lStripe" (
    id_log_stripe INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_usuario INT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE SET NULL,
    mensaje_error VARCHAR(500),
    detalle_error TEXT,
    clase VARCHAR(100),
    metodo VARCHAR(100),
    ip_address INET,
    user_agent TEXT,
    fecha_error_log TIMESTAMP DEFAULT NOW()
);

CREATE TABLE usuario."tSesion" (
    id_sesion UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_usuario INT NOT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE CASCADE,
    refresh_token_hash TEXT NOT NULL,
    ip_address INET,
    user_agent TEXT,
    created_at TIMESTAMP DEFAULT NOW(),
    expires_at TIMESTAMP NOT NULL,
    revoked BOOLEAN DEFAULT FALSE,
    revoked_at TIMESTAMP
);

CREATE TABLE usuario."tMetodoPago" (
    id_metodo INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_usuario INT NOT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE CASCADE,
    stripe_payment_method_id VARCHAR(100) NOT NULL UNIQUE, -- pm_xxx
    tipo VARCHAR(20) NOT NULL, -- 'card', 'oxxo', 'spei'
    marca VARCHAR(20), -- 'visa', 'mastercard', etc.
    ultimos_digitos CHAR(4),
    expira_mes INT CHECK (expira_mes BETWEEN 1 AND 12),
    expira_anio INT,
    es_predeterminado BOOLEAN DEFAULT FALSE,
    activo BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE usuario."tUsuarioSuscripcion" (
    id_suscripcion INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_usuario INT NOT NULL REFERENCES usuario."tUsuario"(id_usuario) ON DELETE CASCADE,
    id_tipo_suscripcion INT NOT NULL REFERENCES usuario."tTipoSuscripcion"(id_tipo_suscripcion),
    fecha_inicio TIMESTAMP DEFAULT NOW(),
    fecha_fin TIMESTAMP, -- NULL = sin expiración (plan Inicio)
    estado VARCHAR(20) DEFAULT 'activa' CHECK (estado IN ('activa', 'cancelada', 'expirada', 'pendiente')),

    -- Stripe
    stripe_subscription_id VARCHAR(100) NULL UNIQUE, -- sub_xxx (NULL para plan Inicio y Prueba sin cargo)

    -- Historial
    convertida_desde_prueba BOOLEAN DEFAULT FALSE, -- true si el usuario venía de una prueba
    cancelar_al_vencer BOOLEAN DEFAULT FALSE, -- true si el usuario canceló pero aún tiene acceso
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP NULL
);

CREATE UNIQUE INDEX idx_usuario_suscripcion_activa ON usuario."tUsuarioSuscripcion" (id_usuario) WHERE estado = 'activa';

CREATE TABLE usuario."tPago" (
    id_pago INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_suscripcion INT NOT NULL REFERENCES usuario."tUsuarioSuscripcion"(id_suscripcion) ON DELETE CASCADE,
    id_tipo_suscripcion INT REFERENCES usuario."tTipoSuscripcion"(id_tipo_suscripcion),
    id_metodo_pago INT REFERENCES usuario."tMetodoPago"(id_metodo),
    monto DECIMAL(10,2) NOT NULL,
    moneda CHAR(3) DEFAULT 'MXN',
    fecha_pago TIMESTAMP DEFAULT NOW(),
    metodo_pago VARCHAR(50), -- 'card', 'oxxo', 'spei'
    ultimos_digitos VARCHAR(4),

    -- Stripe
    stripe_payment_intent_id VARCHAR(100) NULL, -- pi_xxx
    stripe_invoice_id VARCHAR(100) NULL, -- in_xxx (para suscripciones recurrentes)
    estado_pago VARCHAR(20) CHECK (estado_pago IN ('exitoso', 'fallido', 'pendiente', 'reembolsado')),
    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE usuario."tWebhookEvent" (
    id_evento BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    stripe_event_id VARCHAR(255) UNIQUE NOT NULL,
    procesado_en TIMESTAMP DEFAULT NOW()
);


-- Índices

-- Usuario
CREATE INDEX idx_usuario_telefono ON usuario."tUsuario" (numero_telefono);
CREATE INDEX idx_usuario_correo ON usuario."tUsuario" (correo_electronico);
CREATE INDEX idx_usuario_stripe ON usuario."tUsuario" (stripe_customer_id);
 
-- Acceso
CREATE INDEX idx_acceso_id_usuario ON usuario."tAcceso" (id_usuario);
CREATE INDEX idx_acceso_bloqueo ON usuario."tAcceso" (bloqueado_hasta) WHERE bloqueado_hasta IS NOT NULL;
 
-- Log
CREATE INDEX idx_log_fecha ON usuario."lAcceso" (fecha_error_log);
CREATE INDEX idx_log_usuario ON usuario."lAcceso" (id_usuario);
CREATE INDEX idx_log_ip ON usuario."lAcceso" (ip_address);
 
-- Sesiones
CREATE INDEX idx_sesion_usuario ON usuario."tSesion" (id_usuario);
CREATE INDEX idx_sesion_expires ON usuario."tSesion" (expires_at);
CREATE INDEX idx_sesion_token_hash ON usuario."tSesion" (refresh_token_hash);
CREATE INDEX idx_sesion_revoked ON usuario."tSesion" (revoked) WHERE revoked = FALSE;
 
-- Métodos de pago
CREATE INDEX idx_metodo_pago_usuario ON usuario."tMetodoPago" (id_usuario);
 
-- Suscripciones
CREATE INDEX idx_suscripcion_usuario ON usuario."tUsuarioSuscripcion" (id_usuario);
CREATE INDEX idx_suscripcion_fecha_fin ON usuario."tUsuarioSuscripcion" (fecha_fin) WHERE estado = 'activa';
CREATE INDEX idx_suscripcion_stripe ON usuario."tUsuarioSuscripcion" (stripe_subscription_id);
 
-- Pagos
CREATE INDEX idx_pago_suscripcion ON usuario."tPago" (id_suscripcion);
CREATE INDEX idx_pago_stripe_pi ON usuario."tPago" (stripe_payment_intent_id);


