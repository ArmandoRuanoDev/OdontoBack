-- Funciones necesarias
-- Funcion de registro
CREATE OR REPLACE FUNCTION usuario.registrar_usuario(
    _nombre_usuario VARCHAR,
    _apellido_paterno VARCHAR,
    _apellido_materno VARCHAR,
    _correo_electronico VARCHAR,
    _numero_telefono VARCHAR,
    _fecha_nacimiento DATE,
    _sexo_usuario CHAR,
    _contrasena_hash TEXT,
    _id_rol_usuario INT,
    _acepta_aviso_privacidad BOOLEAN,
    _acepta_terminos_condiciones BOOLEAN
)
RETURNS JSON AS $$
DECLARE
    nuevo_id INT;
    resultado JSON;
    fecha_ahora TIMESTAMP := NOW();
    suscripcion_id INT;
    duracion INT;
BEGIN
    IF _acepta_aviso_privacidad IS FALSE OR _acepta_terminos_condiciones IS FALSE THEN
        RAISE EXCEPTION 'Debe aceptar el aviso de privacidad y los términos y condiciones para registrarse';
    END IF;

    -- Insertar en tUsuario
    INSERT INTO usuario."tUsuario" (
        nombre_usuario, apellido_paterno, apellido_materno,
        correo_electronico, numero_telefono, fecha_nacimiento,
        sexo_usuario, contrasena_hash, id_rol_usuario,
        acepta_aviso_privacidad, fecha_aceptacion_aviso,
        acepta_terminos_condiciones, fecha_aceptacion_terminos
    ) VALUES (
        _nombre_usuario, _apellido_paterno, _apellido_materno,
        _correo_electronico, _numero_telefono, _fecha_nacimiento,
        _sexo_usuario, _contrasena_hash, _id_rol_usuario,
        _acepta_aviso_privacidad, fecha_ahora,
        _acepta_terminos_condiciones, fecha_ahora
    )
    RETURNING id_usuario INTO nuevo_id;

    -- Insertar en tAcceso
    INSERT INTO usuario."tAcceso" (id_usuario)
    VALUES (nuevo_id);

    -- Obtener datos del tipo de suscripción 'Inicio'
    SELECT id_tipo_suscripcion, duracion_dias
    INTO suscripcion_id, duracion
    FROM usuario."tTipoSuscripcion"
    WHERE nombre = 'Inicio' AND activo = true;

    -- Insertar en tUsuarioSuscripcion con fecha_fin según duración (NULL si duracion es NULL)
    INSERT INTO usuario."tUsuarioSuscripcion" (
        id_usuario, id_tipo_suscripcion, fecha_inicio, fecha_fin, estado
    ) VALUES (
        nuevo_id, suscripcion_id, fecha_ahora,
        CASE WHEN duracion IS NOT NULL THEN fecha_ahora + (duracion || ' days')::INTERVAL ELSE NULL END,
        'activa'
    );

    -- Devolver datos del nuevo usuario
    SELECT json_build_object(
        'id', nuevo_id,
        'nombre_usuario', _nombre_usuario,
        'correo_electronico', _correo_electronico
    ) INTO resultado;

    RETURN resultado;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Funcion para suscripciones expiradas
CREATE OR REPLACE FUNCTION usuario.actualizar_suscripciones_expiradas()
RETURNS INTEGER AS $$
DECLARE
    actualizadas_primera INTEGER;
    actualizadas_segunda INTEGER;
    total INTEGER;
BEGIN
    UPDATE usuario."tUsuarioSuscripcion"
    SET estado = 'pendiente',
        fecha_fin = NOW() + INTERVAL '2 days',
        updated_at = NOW()
    WHERE estado = 'activa'
      AND fecha_fin IS NOT NULL
      AND fecha_fin < NOW();
    
    GET DIAGNOSTICS actualizadas_primera = ROW_COUNT;
    
    UPDATE usuario."tUsuarioSuscripcion"
    SET estado = 'expirada', updated_at = NOW()
    WHERE estado = 'pendiente'
      AND updated_at < NOW() - INTERVAL '2 days';
    
    GET DIAGNOSTICS actualizadas_segunda = ROW_COUNT;
    
    total := actualizadas_primera + actualizadas_segunda;
    
    RETURN total;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Funcion para renovar suscripciones
CREATE OR REPLACE FUNCTION usuario.reactivar_suscripcion(
    _id_suscripcion INT,
    _nuevos_dias INT  -- días adicionales a partir de hoy
)
RETURNS VOID AS $$
BEGIN
    UPDATE usuario."tUsuarioSuscripcion"
    SET estado = 'activa',
        fecha_inicio = NOW(),
        fecha_fin = NOW() + (_nuevos_dias || ' days')::INTERVAL,
        updated_at = NOW()
    WHERE id_suscripcion = _id_suscripcion
      AND estado IN ('pendiente', 'expirada');
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Permisos de acceso
GRANT USAGE ON SCHEMA usuario TO anon, authenticated, service_role;
GRANT ALL ON ALL TABLES IN SCHEMA usuario TO anon, authenticated, service_role;
ALTER DEFAULT PRIVILEGES IN SCHEMA usuario
GRANT ALL ON TABLES TO anon, authenticated, service_role;